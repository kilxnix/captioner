<?xml version="1.0" encoding="utf-8"?>
<!-- Cole's Log: a soft-serve swirl resting on a piece of notepaper.
     Drawn in the standard 108dp adaptive-icon canvas; everything important
     stays inside the 66dp safe-zone in the center. -->
